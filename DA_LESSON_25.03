 select position('world' in 'hello world my friends');
 
-- написать запрос, который выводит имя, фамилию и юзернейм (юзернейм - подстрока в почте до @)

select
	first_name,
	last_name,
	substring(email, 1, position('@' in email) - 1) as username
 from employees;
