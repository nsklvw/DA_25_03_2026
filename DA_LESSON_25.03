create schema sbx;

set search_path to sbx;

---------------------------------------------

drop table if exists employees_programmer;
create table employees_programmer as
select
	employee_id,
	first_name,
	last_name,
	email,
	phone,
	hire_date,
	manager_id
from lessons_database.employees
where job_title = 'Programmer';

---------------------------------------------

create view v_employees_programmer as
select
	employee_id,
	first_name,
	last_name,
	email,
	phone,
	hire_date,
	manager_id
from lessons_database.employees
where job_title = 'Programmer';

---------------------------------------------

update lessons_database.employees
set manager_id = manager_id + 1
where job_title = 'Programmer';

update lessons_database.employees
set manager_id = manager_id - 1
where job_title = 'Programmer';

---------------------------------------------

select * from employees_programmer;

select * from v_employees_programmer;

