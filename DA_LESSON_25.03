select length('hello');
select upper('hello');
select lower('hello');

select substring('PostgreSQL lesson', 8, 3); -- с 8 символа 3 следующих
select substring('PostgreSQL lesson', 8); -- с 8 символа
select substring('PostgreSQL lesson' from 8); -- не использовать from
select substring('PostgreSQL lesson', length('PostgreSQL lesson') - 5); -- с обратной стороны

---------------------------------------------

-- сформировать поле short_name, которое состоит из первых пяти символов имени компании и трех точек

select 
	name,
	substring(name, 1, 5) || '...' as short_name
from customers;
 
-- добавить проверку: если длина имени больше четырех символов, то обрезать и добавить троеточие. в ином случае оставить имя как есть

select
	name,
	case 
		when length(name) > 4 
			then trim(substring(name, 1, 5)) || '...'
		else name
	end as short_name
from customers;

select trim('      hello world      ');

