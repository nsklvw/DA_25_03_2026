- малая нагрузка на жесткий диск
- более свежие данные в реальном времени

table

- маленькая нагрузка на оперативную память
- большая нагрузка на жесткий диск
- данные на момент создания

---------------------------------------------

select concat('hello', 'world');
select concat('hello', ' ', 'world', ' ', 'bibi', ' ', 'labu');
select concat_ws(' ', 'hello', 'world', 'bibi', 'labu');
select 'hello' || ' ' || 'world' as new_column;

---------------------------------------------

set search_path to lessons_database;

select * from employees;

---------------------------------------------

-- написать запрос, который выводит first_name, last_name, full_name

select first_name || ' ' || last_name as full_name
from employees;

-- если empoloyee_id четный, то пол мужской, в ином случае женский

select 
    first_name || ' ' || last_name as full_name,
    employee_id,
    case 
        when employee_id % 2 = 0 then 'Mr'
        else 'Ms'
    end as gender
from employees;

-- к каждому full_name добавить mr или ms

select 
	concat_ws(' ',
		case 
	        when employee_id % 2 = 0 then 'Mr.'
	        else 'Ms.'
	    end,
	    first_name,
	    last_name
	   ) as full_name
	from employees;

